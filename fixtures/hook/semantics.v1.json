{
  "schemaVersion": "uvp.hookSemanticsCorpus.v1",
  "wikiRefs": [
    "uvp-wiki/wiki/concepts/core/hook.md",
    "uvp-wiki/wiki/concepts/core/signal.md",
    "uvp-wiki/wiki/concepts/core/source.md",
    "uvp-wiki/wiki/concepts/core/trigger.md",
    "uvp-wiki/wiki/concepts/state-machine/evaluation.md",
    "uvp-wiki/wiki/concepts/state-machine/timers-and-status.md",
    "uvp-wiki/wiki/concepts/state-machine/replay.md"
  ],
  "runtimeDeliveryModel": {
    "evm": "Core semantics produce chain events and replayable projections. Users or services may fetch results from chain/indexer.",
    "cloud": "Core semantics produce the same state, but cloud runtime can treat the engine as a black box and push computed user messages directly."
  },
  "parseCases": [
    {
      "name": "single positive signal",
      "profile": "evm_strict",
      "hookName": "START",
      "hook": "buyer::task.main.cmp",
      "expect": {
        "source": "buyer",
        "mode": "normal",
        "runtimeCondition": "task.main.cmp",
        "normalizedExpression": "buyer::task.main.cmp",
        "dependencies": [
          { "kind": "positive", "source": "buyer", "signalName": "task.main.cmp" }
        ]
      }
    },
    {
      "name": "delay with monotonic negative guard",
      "profile": "evm_strict",
      "hookName": "TIMEOUT",
      "hook": "buyer::(task.pay.cmp +5s) & ~task.refund.cmp",
      "expect": {
        "source": "buyer",
        "mode": "normal",
        "runtimeCondition": "task.pay.cmp+5s&~task.refund.cmp",
        "normalizedExpression": "buyer::task.pay.cmp+5s&~task.refund.cmp",
        "dependencies": [
          { "kind": "negative", "source": "buyer", "signalName": "task.refund.cmp" },
          { "kind": "positive", "source": "buyer", "signalName": "task.pay.cmp" },
          { "kind": "timer", "source": "buyer", "signalName": "task.pay.cmp", "delaySeconds": 5 }
        ]
      }
    },
    {
      "name": "cross source outsource target",
      "profile": "evm_strict",
      "hookName": "CHILD_DONE",
      "hook": "local::OUTSOURCE@(peer::child.close.cmp)",
      "expect": {
        "source": "local",
        "mode": "outsource",
        "upstreamSource": "peer",
        "runtimeCondition": "OUTSOURCE@(peer::child.close.cmp)",
        "normalizedExpression": "local::OUTSOURCE@(peer::child.close.cmp)",
        "dependencies": [
          { "kind": "positive", "source": "peer", "signalName": "child.close.cmp" }
        ]
      }
    },
    {
      "name": "cloud outside maps empty source to hook name",
      "profile": "cloud_compat",
      "hookName": "LINK_READY",
      "hook": "::OUTSIDE",
      "expect": {
        "source": "",
        "mode": "outside",
        "runtimeCondition": "LINK_READY",
        "normalizedExpression": "::OUTSIDE",
        "dependencies": [
          { "kind": "positive", "source": "", "signalName": "LINK_READY" }
        ]
      }
    },
    {
      "name": "cloud outside target keeps target source",
      "profile": "cloud_compat",
      "hookName": "REG_CHILD",
      "hook": "::OUTSIDE@(test_executor::dispatch.main.smart_contract)",
      "expect": {
        "source": "",
        "mode": "outside_spawn",
        "upstreamSource": "test_executor",
        "runtimeCondition": "dispatch.main.smart_contract",
        "normalizedExpression": "::OUTSIDE@(test_executor::dispatch.main.smart_contract)",
        "dependencies": [
          { "kind": "positive", "source": "test_executor", "signalName": "dispatch.main.smart_contract" }
        ]
      }
    },
    {
      "name": "cloud outsource target with same source condition terms",
      "profile": "cloud_compat",
      "hookName": "CALLBACK",
      "hook": "::OUTSOURCE@(seller::task.a.cmp & task.b.cmp | task.c.cmp)",
      "expect": {
        "source": "",
        "mode": "outsource",
        "upstreamSource": "seller",
        "runtimeCondition": "task.a.cmp & task.b.cmp | task.c.cmp",
        "normalizedExpression": "::OUTSOURCE@(seller::(task.a.cmp&task.b.cmp)|task.c.cmp)",
        "dependencies": [
          { "kind": "positive", "source": "seller", "signalName": "task.a.cmp" },
          { "kind": "positive", "source": "seller", "signalName": "task.b.cmp" },
          { "kind": "positive", "source": "seller", "signalName": "task.c.cmp" }
        ]
      }
    }
  ],
  "evalCases": [
    {
      "name": "missing signal needs more",
      "profile": "evm_strict",
      "hookName": "START",
      "hook": "buyer::task.main.cmp",
      "now": "2026-04-27T00:00:00.000Z",
      "signals": [],
      "expect": { "state": "needs_more" }
    },
    {
      "name": "single positive signal ready",
      "profile": "evm_strict",
      "hookName": "START",
      "hook": "buyer::task.main.cmp",
      "now": "2026-04-27T00:00:00.000Z",
      "signals": [
        { "source": "buyer", "signalName": "task.main.cmp", "receivedAt": "2026-04-27T00:00:00.000Z" }
      ],
      "expect": { "state": "ready" }
    },
    {
      "name": "same signal name under another source does not satisfy evm hook",
      "profile": "evm_strict",
      "hookName": "START",
      "hook": "buyer::task.main.cmp",
      "now": "2026-04-27T00:00:00.000Z",
      "signals": [
        { "source": "seller", "signalName": "task.main.cmp", "receivedAt": "2026-04-27T00:00:00.000Z" }
      ],
      "expect": { "state": "needs_more" }
    },
    {
      "name": "same signal name under another source does not satisfy cloud hook",
      "profile": "cloud_compat",
      "hookName": "START",
      "hook": "buyer::task.main.cmp",
      "now": "2026-04-27T00:00:00.000Z",
      "signals": [
        { "source": "seller", "signalName": "task.main.cmp", "receivedAt": "2026-04-27T00:00:00.000Z" }
      ],
      "expect": { "state": "needs_more" }
    },
    {
      "name": "source-less signal does not satisfy sourced cloud hook",
      "profile": "cloud_compat",
      "hookName": "START",
      "hook": "buyer::task.main.cmp",
      "now": "2026-04-27T00:00:00.000Z",
      "signals": [
        { "source": "", "signalName": "task.main.cmp", "receivedAt": "2026-04-27T00:00:00.000Z" }
      ],
      "expect": { "state": "needs_more" }
    },
    {
      "name": "evm delay waits at chain second precision",
      "profile": "evm_strict",
      "hookName": "TIMEOUT",
      "hook": "buyer::task.pay.cmp +5s",
      "now": "2026-04-27T00:00:04.999Z",
      "signals": [
        { "source": "buyer", "signalName": "task.pay.cmp", "receivedAt": "2026-04-27T00:00:00.900Z" }
      ],
      "expect": { "state": "wait", "readyAt": "2026-04-27T00:00:05.000Z" }
    },
    {
      "name": "cloud delay preserves subsecond timestamp",
      "profile": "cloud_compat",
      "hookName": "TIMEOUT",
      "hook": "buyer::task.pay.cmp +5s",
      "now": "2026-04-27T00:00:05.899Z",
      "signals": [
        { "source": "buyer", "signalName": "task.pay.cmp", "receivedAt": "2026-04-27T00:00:00.900Z" }
      ],
      "expect": { "state": "wait", "readyAt": "2026-04-27T00:00:05.900Z" }
    },
    {
      "name": "delay ready after due time",
      "profile": "evm_strict",
      "hookName": "TIMEOUT",
      "hook": "buyer::task.pay.cmp +5s",
      "now": "2026-04-27T00:00:05.001Z",
      "signals": [
        { "source": "buyer", "signalName": "task.pay.cmp", "receivedAt": "2026-04-27T00:00:00.900Z" }
      ],
      "expect": { "state": "ready", "readyAt": "2026-04-27T00:00:05.000Z" }
    },
    {
      "name": "negative guard cancels monotonically",
      "profile": "evm_strict",
      "hookName": "PAY",
      "hook": "buyer::task.pay.cmp & ~task.refund.cmp",
      "now": "2026-04-27T00:00:06.000Z",
      "signals": [
        { "source": "buyer", "signalName": "task.pay.cmp", "receivedAt": "2026-04-27T00:00:00.000Z" },
        { "source": "buyer", "signalName": "task.refund.cmp", "receivedAt": "2026-04-27T00:00:03.000Z" }
      ],
      "expect": { "state": "impossible", "reasonContains": "negated condition exists: task.refund.cmp" }
    },
    {
      "name": "and waits on latest delayed branch",
      "profile": "evm_strict",
      "hookName": "BOTH",
      "hook": "buyer::(task.a.cmp +5s) & (task.b.cmp +10s)",
      "now": "2026-04-27T00:00:00.000Z",
      "signals": [
        { "source": "buyer", "signalName": "task.a.cmp", "receivedAt": "2026-04-27T00:00:00.000Z" },
        { "source": "buyer", "signalName": "task.b.cmp", "receivedAt": "2026-04-27T00:00:00.000Z" }
      ],
      "expect": { "state": "wait", "readyAt": "2026-04-27T00:00:10.000Z" }
    },
    {
      "name": "or waits on earliest live delayed branch",
      "profile": "evm_strict",
      "hookName": "ANY",
      "hook": "buyer::(task.a.cmp +5s) | (task.b.cmp +10s)",
      "now": "2026-04-27T00:00:00.000Z",
      "signals": [
        { "source": "buyer", "signalName": "task.a.cmp", "receivedAt": "2026-04-27T00:00:00.000Z" },
        { "source": "buyer", "signalName": "task.b.cmp", "receivedAt": "2026-04-27T00:00:00.000Z" }
      ],
      "expect": { "state": "wait", "readyAt": "2026-04-27T00:00:05.000Z" }
    },
    {
      "name": "all or branches cancelled",
      "profile": "evm_strict",
      "hookName": "ANY",
      "hook": "buyer::(task.a.cmp & ~task.cancel.cmp) | (task.b.cmp & ~task.fail.cmp)",
      "now": "2026-04-27T00:00:00.000Z",
      "signals": [
        { "source": "buyer", "signalName": "task.cancel.cmp", "receivedAt": "2026-04-27T00:00:00.000Z" },
        { "source": "buyer", "signalName": "task.fail.cmp", "receivedAt": "2026-04-27T00:00:00.000Z" }
      ],
      "expect": { "state": "impossible", "reasonContains": "all OR branches are cancelled" }
    },
    {
      "name": "outsource target uses upstream source",
      "profile": "evm_strict",
      "hookName": "CHILD_DONE",
      "hook": "local::OUTSOURCE@(peer::child.close.cmp)",
      "now": "2026-04-27T00:00:00.000Z",
      "signals": [
        { "source": "peer", "signalName": "child.close.cmp", "receivedAt": "2026-04-27T00:00:00.000Z" }
      ],
      "expect": { "state": "ready" }
    }
  ],
  "invalidCases": [
    { "name": "missing source separator", "profile": "evm_strict", "hookName": "HOOK", "hook": "task.main.cmp", "messageContains": "must contain" },
    { "name": "empty source only allowed for external hooks", "profile": "cloud_compat", "hookName": "HOOK", "hook": "::task.main.cmp", "messageContains": "empty source is only allowed" },
    { "name": "single segment short name", "profile": "cloud_compat", "hookName": "HOOK", "hook": "buyer::cmp", "messageContains": "task.stage.signal" },
    { "name": "two segment short name", "profile": "evm_strict", "hookName": "HOOK", "hook": "buyer::main.cmp", "messageContains": "task.stage.signal" },
    { "name": "four segment signal name", "profile": "evm_strict", "hookName": "HOOK", "hook": "buyer::task.stage.signal.extra", "messageContains": "task.stage.signal" },
    { "name": "empty signal segment", "profile": "evm_strict", "hookName": "HOOK", "hook": "buyer::task..cmp", "messageContains": "task.stage.signal" },
    { "name": "pure absence has no positive anchor", "profile": "evm_strict", "hookName": "HOOK", "hook": "buyer::~task.cancel.cmp", "messageContains": "positive signal anchor" },
    { "name": "or branch must have positive anchor", "profile": "evm_strict", "hookName": "HOOK", "hook": "buyer::task.ok.cmp | ~task.cancel.cmp", "messageContains": "each OR branch" },
    { "name": "legacy plus T is rejected", "profile": "cloud_compat", "hookName": "HOOK", "hook": "buyer::task.pay.cmp+T", "messageContains": "legacy +T" },
    { "name": "zero delay is rejected", "profile": "evm_strict", "hookName": "HOOK", "hook": "buyer::task.pay.cmp +0s", "messageContains": "invalid duration" },
    { "name": "nested external is rejected", "profile": "cloud_compat", "hookName": "HOOK", "hook": "::OUTSOURCE@(seller::OUTSIDE@(buyer::task.main.cmp))", "messageContains": "nested OUTSIDE/OUTSOURCE" }
  ],
